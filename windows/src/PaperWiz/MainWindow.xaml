<Window x:Class="PaperWiz.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PaperWiz.ViewModels"
        Title="paperWiz"
        Icon="Assets/paperwiz.ico"
        Height="740" Width="1080" MinHeight="600" MinWidth="920"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}"
        AllowDrop="True"
        Drop="OnFileDrop" DragOver="OnDragOver"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">

    <Window.DataContext>
        <vm:MainViewModel />
    </Window.DataContext>

    <Grid Margin="22,18,22,18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ================= Header ================= -->
        <Grid Grid.Row="0" Margin="2,0,2,16">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="paper" Style="{StaticResource H1}" />
                    <TextBlock Text="Wiz" Style="{StaticResource H1}" Foreground="{StaticResource Brand}" />
                </StackPanel>
                <TextBlock Text="Per-monitor wallpapers that share your wallpaper's colour."
                           Foreground="{StaticResource TextMuted}" FontSize="12.5" Margin="0,2,0,0" />
            </StackPanel>
            <Button Content="⟳  Refresh displays" Style="{StaticResource GhostButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Command="{Binding RefreshMonitorsCommand}" />
        </Grid>

        <!-- ================= Body ================= -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="392" />
                <ColumnDefinition Width="18" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- ===== Left: controls ===== -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,6,0">
                <StackPanel>

                    <!-- Wallpaper -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="WALLPAPER" Style="{StaticResource SectionLabel}" />

                            <!-- The whole preview is one Button, so the file dialog opens exactly once. -->
                            <Button Height="168" Cursor="Hand" Command="{Binding BrowseCommand}"
                                    HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="dz" CornerRadius="10" BorderThickness="1.5"
                                                BorderBrush="{StaticResource CardBorderStrong}" ClipToBounds="True">
                                            <Border.Background>
                                                <ImageBrush ImageSource="{Binding WallpaperThumbnail}" Stretch="UniformToFill" />
                                            </Border.Background>
                                            <Grid>
                                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                                            Visibility="{Binding HasWallpaper, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                                    <TextBlock Text="🖼" FontSize="30" HorizontalAlignment="Center"
                                                               Foreground="{StaticResource TextFaint}" />
                                                    <TextBlock Text="Drop an image here" HorizontalAlignment="Center"
                                                               Margin="0,8,0,0" Foreground="{StaticResource TextMuted}" />
                                                    <TextBlock Text="or click to browse" HorizontalAlignment="Center"
                                                               Foreground="{StaticResource TextFaint}" FontSize="11.5" />
                                                </StackPanel>
                                                <Border VerticalAlignment="Bottom" Background="#B4000000" Padding="12,7"
                                                        Visibility="{Binding HasWallpaper, Converter={StaticResource BoolToVis}}">
                                                    <Grid>
                                                        <TextBlock Text="{Binding WallpaperFileName}" Foreground="White"
                                                                   TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" />
                                                        <TextBlock Text="{Binding WallpaperDimensions}" Foreground="#CFD3DC"
                                                                   FontSize="11.5" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="dz" Property="BorderBrush" Value="{StaticResource Brand}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="8" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="Open file…" Command="{Binding BrowseCommand}" />
                                <Button Grid.Column="2" Content="Open folder…" Command="{Binding OpenFolderCommand}" />
                            </Grid>

                            <UniformGrid Rows="1" Columns="2" Margin="0,8,0,0">
                                <Button Content="↶  Rotate left" Style="{StaticResource GhostButton}"
                                        Command="{Binding RotateLeftCommand}" IsEnabled="{Binding HasWallpaper}" />
                                <Button Content="↷  Rotate right" Style="{StaticResource GhostButton}"
                                        Command="{Binding RotateRightCommand}" IsEnabled="{Binding HasWallpaper}" />
                            </UniformGrid>

                            <!-- Folder gallery -->
                            <StackPanel Margin="0,12,0,0"
                                        Visibility="{Binding HasFolderImages, Converter={StaticResource BoolToVis}}">
                                <TextBlock Style="{StaticResource Caption}" FontWeight="Normal"
                                           Foreground="{StaticResource TextFaint}" Margin="2,0,0,7"
                                           Text="{Binding CurrentFolderName, StringFormat='📁 {0} — click a photo'}" />
                                <ScrollViewer MaxHeight="196" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                                    <ItemsControl ItemsSource="{Binding FolderImages}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Width="76" Height="76" Margin="0,0,7,7" Cursor="Hand"
                                                        ToolTip="{Binding FileName}"
                                                        Command="{Binding DataContext.SelectFolderImageCommand,
                                                                  RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Grid>
                                                                <Border x:Name="tb" CornerRadius="7" ClipToBounds="True"
                                                                        BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                                                                    <Border.Background>
                                                                        <ImageBrush ImageSource="{Binding Thumbnail}" Stretch="UniformToFill" />
                                                                    </Border.Background>
                                                                </Border>
                                                                <Border x:Name="tring" CornerRadius="7" BorderThickness="2"
                                                                        BorderBrush="{StaticResource Brand}"
                                                                        Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />
                                                            </Grid>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="tb" Property="BorderBrush" Value="{StaticResource BrandHover}" />
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Accent colour -->
                    <Border Style="{StaticResource Card}" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="ACCENT COLOUR" Style="{StaticResource SectionLabel}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Current colour swatch opens the picker -->
                                <ToggleButton x:Name="ColorToggle" Grid.Column="0" Width="46" Height="46"
                                              Cursor="Hand" Background="Transparent" BorderThickness="0">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border CornerRadius="9" Background="{Binding AccentBrush}"
                                                    BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1" />
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <!-- RGB picker popup -->
                                <Popup Grid.Column="0" PlacementTarget="{Binding ElementName=ColorToggle}"
                                       Placement="Bottom" VerticalOffset="8"
                                       IsOpen="{Binding IsChecked, ElementName=ColorToggle}"
                                       StaysOpen="False" AllowsTransparency="True" PopupAnimation="Fade">
                                    <Border Width="272" Background="{StaticResource Surface}" CornerRadius="11"
                                            BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1" Padding="16">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="34" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="R" Foreground="#F47" VerticalAlignment="Center" />
                                                <Slider Grid.Column="1" Minimum="0" Maximum="255" Margin="8,0"
                                                        Value="{Binding AccentR, Mode=TwoWay}" />
                                                <TextBlock Grid.Column="2" Text="{Binding AccentR}" TextAlignment="Right"
                                                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                                            </Grid>
                                            <Grid Margin="0,0,0,10">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="34" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="G" Foreground="#5D7" VerticalAlignment="Center" />
                                                <Slider Grid.Column="1" Minimum="0" Maximum="255" Margin="8,0"
                                                        Value="{Binding AccentG, Mode=TwoWay}" />
                                                <TextBlock Grid.Column="2" Text="{Binding AccentG}" TextAlignment="Right"
                                                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                                            </Grid>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="18" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="34" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="B" Foreground="#59F" VerticalAlignment="Center" />
                                                <Slider Grid.Column="1" Minimum="0" Maximum="255" Margin="8,0"
                                                        Value="{Binding AccentB, Mode=TwoWay}" />
                                                <TextBlock Grid.Column="2" Text="{Binding AccentB}" TextAlignment="Right"
                                                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </Popup>

                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBox Text="{Binding AccentHex, UpdateSourceTrigger=PropertyChanged}"
                                             FontFamily="Cascadia Mono, Consolas" />
                                    <TextBlock Style="{StaticResource Caption}" FontWeight="Normal" Margin="2,9,0,0"
                                               TextWrapping="Wrap" Foreground="{StaticResource TextFaint}"
                                               Text="Your pick below is remembered and re-derived from each new photo." />
                                </StackPanel>
                            </Grid>

                            <!-- Pywal-style palette (shown first, as requested) -->
                            <StackPanel Margin="0,16,0,0"
                                        Visibility="{Binding HasWallpaper, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Pywal palette — complementary scheme (hover for the role)"
                                           Style="{StaticResource Caption}" FontWeight="Normal"
                                           Foreground="{StaticResource TextFaint}" Margin="2,0,0,8" />
                                <ItemsControl ItemsSource="{Binding PywalPalette}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Width="37" Height="37" Margin="0,0,5,5" Cursor="Hand"
                                                    ToolTip="{Binding Reason}"
                                                    Command="{Binding DataContext.SelectSwatchCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Grid>
                                                            <Border x:Name="sw" CornerRadius="7" Background="{Binding Brush}"
                                                                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1" />
                                                            <Border x:Name="ring" CornerRadius="7" BorderThickness="2"
                                                                    BorderBrush="{StaticResource Brand}"
                                                                    Visibility="{Binding IsSelected, Converter={StaticResource BoolToVis}}" />
                                                        </Grid>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="sw" Property="BorderBrush" Value="{StaticResource BrandHover}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>

                            <!-- Labelled suggestions extracted from the wallpaper (kept below) -->
                            <StackPanel Margin="0,14,0,0"
                                        Visibility="{Binding HasWallpaper, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="From your wallpaper — the label says why"
                                           Style="{StaticResource Caption}" FontWeight="Normal"
                                           Foreground="{StaticResource TextFaint}" Margin="2,0,0,8" />
                                <ItemsControl ItemsSource="{Binding Palette}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Margin="0,0,0,6" Cursor="Hand" HorizontalContentAlignment="Stretch"
                                                    ToolTip="{Binding Reason}"
                                                    Command="{Binding DataContext.SelectSwatchCommand,
                                                              RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border x:Name="row" CornerRadius="8" Padding="8,7"
                                                                Background="{StaticResource SurfaceAlt}"
                                                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="Auto" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border Grid.Column="0" Width="26" Height="26" CornerRadius="6"
                                                                        Background="{Binding Brush}"
                                                                        BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Label}" Margin="12,0,0,0"
                                                                           VerticalAlignment="Center" Foreground="{StaticResource Text}" />
                                                                <TextBlock Grid.Column="2" Text="{Binding Hex}" VerticalAlignment="Center"
                                                                           FontFamily="Cascadia Mono, Consolas" FontSize="11.5"
                                                                           Foreground="{StaticResource TextMuted}" />
                                                            </Grid>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="row" Property="Background" Value="{StaticResource SurfaceHover}" />
                                                            </Trigger>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter TargetName="row" Property="Background" Value="{StaticResource BrandDim}" />
                                                                <Setter TargetName="row" Property="BorderBrush" Value="{StaticResource Brand}" />
                                                            </DataTrigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Placement -->
                    <Border Style="{StaticResource Card}">
                        <StackPanel>
                            <TextBlock Text="PLACEMENT" Style="{StaticResource SectionLabel}" />

                            <!-- Fit mode segmented control -->
                            <Border Background="{StaticResource SurfaceAlt}" CornerRadius="9" Padding="3"
                                    BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                                <UniformGrid Rows="1" Columns="3">
                                    <RadioButton Content="Auto" GroupName="fit" Style="{StaticResource SegmentedRadio}"
                                                 IsChecked="{Binding FitMode, Converter={StaticResource EnumEquals}, ConverterParameter=Auto, Mode=TwoWay}" />
                                    <RadioButton Content="Frame" GroupName="fit" Style="{StaticResource SegmentedRadio}"
                                                 IsChecked="{Binding FitMode, Converter={StaticResource EnumEquals}, ConverterParameter=Frame, Mode=TwoWay}" />
                                    <RadioButton Content="Cover" GroupName="fit" Style="{StaticResource SegmentedRadio}"
                                                 IsChecked="{Binding FitMode, Converter={StaticResource EnumEquals}, ConverterParameter=Cover, Mode=TwoWay}" />
                                </UniformGrid>
                            </Border>
                            <TextBlock Text="Auto covers large wallpapers and frames smaller ones with the accent colour."
                                       Style="{StaticResource Caption}" FontWeight="Normal" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextFaint}" Margin="2,7,0,0" />

                            <!-- Position anchor grid -->
                            <TextBlock Text="Position when framed" Margin="2,16,0,0"
                                       Foreground="{StaticResource TextMuted}" FontSize="12.5" />
                            <UniformGrid Rows="3" Columns="3" HorizontalAlignment="Left" Margin="0,8,0,0">
                                <RadioButton GroupName="anchor" Style="{StaticResource AnchorTile}"
                                             IsChecked="{Binding Anchor, Converter={StaticResource EnumEquals}, ConverterParameter=TopLeft, Mode=TwoWay}" />
                                <RadioButton GroupName="anchor" Style="{StaticResource AnchorTile}"
                                             IsChecked="{Binding Anchor, Converter={StaticResource EnumEquals}, ConverterParameter=Top, Mode=TwoWay}" />
                                <RadioButton GroupName="anchor" Style="{StaticResource AnchorTile}"
                                             IsChecked="{Binding Anchor, Converter={StaticResource EnumEquals}, ConverterParameter=TopRight, Mode=TwoWay}" />
                                <RadioButton GroupName="anchor" Style="{StaticResource AnchorTile}"
                                             IsChecked="{Binding Anchor, Converter={StaticResource EnumEquals}, ConverterParameter=Left, Mode=TwoWay}" />
                                <RadioButton GroupName="anchor" Style="{StaticResource AnchorTile}"
                                             IsChecked="{Binding Anchor, Converter={StaticResource EnumEquals}, ConverterParameter=Center, Mode=TwoWay}" />
                                <RadioButton GroupName="anchor" Style="{StaticResource AnchorTile}"
                                             IsChecked="{Binding Anchor, Converter={StaticResource EnumEquals}, ConverterParameter=Right, Mode=TwoWay}" />
                                <RadioButton GroupName="anchor" Style="{StaticResource AnchorTile}"
                                             IsChecked="{Binding Anchor, Converter={StaticResource EnumEquals}, ConverterParameter=BottomLeft, Mode=TwoWay}" />
                                <RadioButton GroupName="anchor" Style="{StaticResource AnchorTile}"
                                             IsChecked="{Binding Anchor, Converter={StaticResource EnumEquals}, ConverterParameter=Bottom, Mode=TwoWay}" />
                                <RadioButton GroupName="anchor" Style="{StaticResource AnchorTile}"
                                             IsChecked="{Binding Anchor, Converter={StaticResource EnumEquals}, ConverterParameter=BottomRight, Mode=TwoWay}" />
                            </UniformGrid>

                            <!-- Shrink -->
                            <CheckBox Content="Shrink tall wallpapers" Margin="0,18,0,0"
                                      IsChecked="{Binding Shrink}" />
                            <StackPanel Orientation="Horizontal" Margin="48,10,0,0"
                                        Visibility="{Binding Shrink, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="Max height" VerticalAlignment="Center"
                                           Foreground="{StaticResource TextMuted}" Margin="0,0,10,0" />
                                <TextBox Width="72" Text="{Binding ShrinkHeight, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBlock Text="px" VerticalAlignment="Center" Margin="8,0,0,0"
                                           Foreground="{StaticResource TextMuted}" />
                            </StackPanel>

                            <!-- Golden-ratio border -->
                            <CheckBox Content="Golden-ratio border" Margin="0,18,0,0"
                                      IsChecked="{Binding GoldenMargin}" />
                            <TextBlock Text="Shrinks the image one golden step (≈62%) so the accent colour frames it."
                                       Style="{StaticResource Caption}" FontWeight="Normal" TextWrapping="Wrap"
                                       Foreground="{StaticResource TextFaint}" Margin="50,6,0,0" />

                            <!-- Fill others -->
                            <CheckBox Content="Fill other monitors with the accent colour" Margin="0,18,0,0"
                                      IsChecked="{Binding FillOtherMonitors}" />
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ===== Right: live preview ===== -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="PREVIEW" Style="{StaticResource SectionLabel}" VerticalAlignment="Center" />
                        <TextBlock Text="Click a display to place the wallpaper there"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextFaint}" FontSize="11.5" />
                    </Grid>

                    <Border Grid.Row="1" Background="{StaticResource WindowBg}" CornerRadius="8"
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                        <ItemsControl x:Name="PreviewHost" ItemsSource="{Binding Monitors}"
                                      SizeChanged="OnPreviewResized" ClipToBounds="True">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding CanvasX}" />
                                    <Setter Property="Canvas.Top" Value="{Binding CanvasY}" />
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}"
                                            Background="Transparent" Cursor="Hand"
                                            Command="{Binding DataContext.SelectMonitorCommand,
                                                      RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Grid>
                                                    <Border x:Name="frame" CornerRadius="5" ClipToBounds="True"
                                                            Background="{Binding AccentBrush}"
                                                            BorderBrush="{StaticResource CardBorderStrong}" BorderThickness="1">
                                                        <Grid>
                                                            <Image Source="{Binding WallpaperImage}"
                                                                   Stretch="{Binding PreviewStretch}"
                                                                   HorizontalAlignment="{Binding PreviewHAlign}"
                                                                   VerticalAlignment="{Binding PreviewVAlign}"
                                                                   Visibility="{Binding ShowWallpaper, Converter={StaticResource BoolToVis}}"
                                                                   RenderTransformOrigin="0.5,0.5">
                                                                <Image.RenderTransform>
                                                                    <ScaleTransform ScaleX="{Binding PreviewScale}" ScaleY="{Binding PreviewScale}" />
                                                                </Image.RenderTransform>
                                                            </Image>
                                                            <Border VerticalAlignment="Bottom" Background="#8C000000" Padding="7,4">
                                                                <TextBlock Text="{Binding Details}" Foreground="#EAECF2"
                                                                           FontSize="10.5" />
                                                            </Border>
                                                        </Grid>
                                                    </Border>
                                                    <Border x:Name="ring" CornerRadius="5" BorderThickness="2"
                                                            BorderBrush="{StaticResource Brand}"
                                                            Visibility="{Binding IsWallpaperMonitor, Converter={StaticResource BoolToVis}}" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="frame" Property="BorderBrush"
                                                                Value="{StaticResource BrandHover}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <!-- ================= Footer ================= -->
        <Grid Grid.Row="2" Margin="2,16,2,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <ProgressBar Width="120" Height="4" IsIndeterminate="True" Margin="0,0,12,0"
                             Background="Transparent" BorderThickness="0" Foreground="{StaticResource Brand}"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}" />
                <TextBlock Text="{Binding Status}" VerticalAlignment="Center"
                           Foreground="{StaticResource TextMuted}" />
            </StackPanel>
            <TextBlock Text="Changes apply automatically" HorizontalAlignment="Right" VerticalAlignment="Center"
                       Foreground="{StaticResource TextFaint}" FontSize="11.5" />
        </Grid>
    </Grid>
</Window>
